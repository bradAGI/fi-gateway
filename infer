# --- pretty output --------------------------------------------------------

class C:
    R = "\033[0m"; G = "\033[32m"; Y = "\033[33m"
    RD = "\033[31m"; D = "\033[2m"; B = "\033[1m"

def out(msg: str = "") -> None: print(msg)
def err(msg: str) -> None: print(f"{C.RD}{msg}{C.R}", file=sys.stderr)
def ok(msg: str) -> None: print(f"{C.G}✓{C.R} {msg}")
def info(label: str, value: str) -> None: print(f"{C.B}{label}:{C.R} {value}")


# --- catalog --------------------------------------------------------------

def load_catalog(refresh_discovery: bool = False) -> list[dict]:
    with PROVIDERS_TOML.open("rb") as f:
        catalog = tomllib.load(f).get("provider", [])
    grouped = grouped_keys()
    for prov in catalog:
        kind = prov.get("discovery")
        if not kind:
            continue
        # Skip discovery for providers without a key — avoids spurious network
        # calls from commands like `./infer keys add`, and hides models the user
        # can't actually call.
        if not (grouped.get(prov["key_env"]) or prov.get("optional_key")):
            continue
        discovered = _run_discovery(kind, refresh=refresh_discovery)
        existing = {m["alias"] for m in prov.get("model", [])}
        prov.setdefault("model", [])
        for m in discovered:
            if m["alias"] not in existing:
                prov["model"].append(m)
    return catalog

def find_provider(name: str) -> dict:
    for p in load_catalog():
        if p["name"] == name:
            return p
    err(f"unknown provider: {name}")
    sys.exit(1)


# --- dynamic discovery ----------------------------------------------------

def _load_discovery_cache(key: str, ignore_ttl: bool = False) -> list[dict] | None:
    if not DISCOVERY_CACHE.exists():
        return None
    try:
        cache = json.loads(DISCOVERY_CACHE.read_text())
    except Exception:
        return None
    entry = cache.get(key)
    if not entry:
        return None
    if not ignore_ttl and time.time() - entry["t"] > DISCOVERY_TTL:
        return None
    return entry["models"]

def _save_discovery_cache(key: str, models: list[dict]) -> None:
    HOME.mkdir(parents=True, exist_ok=True)
    cache: dict = {}
    if DISCOVERY_CACHE.exists():
        try:
            cache = json.loads(DISCOVERY_CACHE.read_text())
        except Exception:
            cache = {}
    cache[key] = {"t": time.time(), "models": models}
    DISCOVERY_CACHE.write_text(json.dumps(cache))


# --- probe cache (per-alias "does this model actually work") --------------

def load_probe_cache(ignore_ttl: bool = False) -> dict | None:
    if not PROBE_CACHE.exists():
        return None
    try:
        data = json.loads(PROBE_CACHE.read_text())
    except Exception:
        return None
    if not ignore_ttl and time.time() - data.get("t", 0) > PROBE_TTL:
        return None
    return data.get("results", {})

def save_probe_cache(results: dict) -> None:
    HOME.mkdir(parents=True, exist_ok=True)
    PROBE_CACHE.write_text(json.dumps({"t": time.time(), "results": results}))

def _run_discovery(kind: str, refresh: bool = False) -> list[dict]:
    handlers = {
        "openrouter_free": _fetch_openrouter_free_models,
        "nvidia_nim": _fetch_nvidia_models,
        "huggingface_inference": _fetch_huggingface_models,
        "pollinations": _fetch_pollinations_models,
        "gemini": _fetch_gemini_models,
    }
    handler = handlers.get(kind)
    if not handler:
        err(f"unknown discovery kind: {kind}")
        return []
    return handler(refresh=refresh)


# Drop entirely — entirely different endpoint shapes that the gateway can't
# proxy through /v1/chat/completions OR /v1/embeddings.
_DROP_NAME_FRAGMENTS = (
    # Image generation
    "/imagen", "imagen-", "/dalle", "dall-e", "stable-diffusion", "/flux",
    "/seedream", "/seedance", "nano-banana",
    # Video generation
    "/veo", "veo-", "lyria", "synthetic-video-detector",
    # Audio / TTS / STT
    "whisper", "/tts", "-tts-", "speech-to-text", "text-to-speech",
    "voxtral", "audio-model",
    # Document parsers (use different request shapes)
    "nemoretriever", "/nemotron-parse", "-parse-",
    # Deprecated
    "/vila",
)

# Embedding models — keep in catalog, tag as `embed`, probe via /v1/embeddings.
_EMBED_NAME_FRAGMENTS = (
    "/embed-", "-embed-v", "embedding-", "/embeddings/", "/embedding-",
    "embed-multilingual", "bge-",
    "embedqa", "embedcode", "nv-embed", "-embedqa", "-embedcode",
    "-embedding", "/embedding",
)

# Reranker models — keep in catalog, tag as `rerank`. No standard probe path
# (each provider's rerank API has a different request shape) so probe skips
# them; users wire up reranking explicitly.
_RERANK_NAME_FRAGMENTS = (
    "rerank-", "-rerank", "/rerank/",
)


def _classify_alias(name: str) -> str:
    """Classify an upstream model id into 'chat' (default), 'embed',
    'rerank', or 'drop'. Used at discovery time to either exclude a model
    or attach the right tag so probe knows which endpoint to hit."""
    n = name.lower()
    if any(f in n for f in _DROP_NAME_FRAGMENTS):
        return "drop"
    if any(f in n for f in _EMBED_NAME_FRAGMENTS):
        return "embed"
    if any(f in n for f in _RERANK_NAME_FRAGMENTS):
        return "rerank"
    return "chat"


# Gemini-specific patterns that aren't even text-generation OR embedding —
# they're entirely separate AI Studio capabilities (image/video/audio/etc.)
# that the gateway can't proxy through chat or /v1/embeddings.
_GEMINI_DROP_PATTERNS = (
    "-image", "-tts", "-audio", "-live-", "-video", "-robotics",
    "imagen", "veo", "lyria", "nano-banana", "computer-use",
    "aqa", "deep-research",
)


def _fetch_gemini_models(refresh: bool = False) -> list[dict]:
    if not refresh:
        cached = _load_discovery_cache("gemini")
        if cached is not None:
            return cached
    keys_for = grouped_keys().get("GEMINI_API_KEY", [])
    if not keys_for:
        return []
    token = load_keys()[keys_for[0]]
    print(f"{C.D}discovering gemini / ai-studio models…{C.R}", file=sys.stderr)
    try:
        req = urllib.request.Request(
            "https://generativelanguage.googleapis.com/v1beta/openai/models",
            headers={"Authorization": f"Bearer {token}"},
        )
        with urllib.request.urlopen(req, timeout=20) as r:
            data = json.loads(r.read())
    except Exception as e:
        err(f"gemini discovery failed: {e}")
        return _load_discovery_cache("gemini", ignore_ttl=True) or []
    models_out: list[dict] = []
    for m in data.get("data", []):
        raw_id = m.get("id") or ""
        # API returns ids like "models/gemini-2.5-flash" — strip prefix
        mid = raw_id.split("/", 1)[-1] if raw_id.startswith("models/") else raw_id
        if not mid:
            continue
        lower = mid.lower()
        if any(pat in lower for pat in _GEMINI_DROP_PATTERNS):
            continue
        cls = _classify_alias(mid)
        if cls == "drop":
            continue
        groups = _infer_gemini_groups(mid)
        if cls == "embed" and "embed" not in groups:
            groups.append("embed")
        if cls == "rerank" and "rerank" not in groups:
            groups.append("rerank")
        models_out.append({
            "alias": mid,
            "upstream": mid,
            "groups": groups,
        })
    _save_discovery_cache("gemini", models_out)
    return models_out


def _infer_gemini_groups(mid: str) -> list[str]:
    tags = ["gemini", "free"]
    n = mid.lower()
    # All modern Gemini + Gemma 3/4 accept image inputs
    if n.startswith("gemini-") or any(s in n for s in ("gemma-3", "gemma-4", "gemma-3n")):
        tags.append("vision")
    if any(s in n for s in ("pro", "3-flash", "3.1-flash", "latest")) and "lite" not in n:
        tags.append("smart")
    if any(s in n for s in ("flash-lite", "flash-lite-latest", "nano", "1b", "2b", "3n-e2b", "3n-e4b")):
        tags.append("fast")
    if "flash" in n and "lite" not in n and "preview" not in n:
        tags.append("fast")
    return tags


def _fetch_nvidia_models(refresh: bool = False) -> list[dict]:
    if not refresh:
        cached = _load_discovery_cache("nvidia_nim")
        if cached is not None:
            return cached
    keys_for = grouped_keys().get("NVIDIA_API_KEY", [])
    if not keys_for:
        return []
    token = load_keys()[keys_for[0]]
    print(f"{C.D}discovering nvidia nim models…{C.R}", file=sys.stderr)
    try:
        req = urllib.request.Request(
            "https://integrate.api.nvidia.com/v1/models",
            headers={"Authorization": f"Bearer {token}"},
        )
        with urllib.request.urlopen(req, timeout=20) as r:
            data = json.loads(r.read())
    except Exception as e:
        err(f"nvidia discovery failed: {e}")
        return _load_discovery_cache("nvidia_nim", ignore_ttl=True) or []
    out = []
    for m in data.get("data", []):
        mid = m.get("id", "")
        if not mid:
            continue
        cls = _classify_alias(mid)
        if cls == "drop":
            continue
        groups = _infer_nvidia_groups(mid)
        if cls == "embed" and "embed" not in groups:
            groups.append("embed")
        if cls == "rerank" and "rerank" not in groups:
            groups.append("rerank")
        out.append({
            "alias": mid,
            "upstream": mid,
            "groups": groups,
        })
    _save_discovery_cache("nvidia_nim", out)
    return out


def _infer_nvidia_groups(mid: str) -> list[str]:
    out = ["nvidia", "free"]
    name = mid.lower()
    if any(t in name for t in ("vl", "vision", "multimodal", "paligemma", "vlm")):
        out.append("vision")
    if any(t in name for t in ("coder", "codestral", "devstral", "code-")):
        out.append("code")
    if any(t in name for t in ("r1", "thinking", "reasoning", "qwq", "magistral", "o1-", "o3-")):
        out.append("reasoning")
    if "embed" in name:
        out.append("embed")
    if "rerank" in name:
        out.append("rerank")
    if any(t in name for t in ("nano", "small", "lite", "flash", "mini", "8b", "9b")):
        out.append("fast")
    if any(t in name for t in ("70b", "120b", "235b", "405b", "480b", "675b", "685b", "1t")):
        out.append("smart")
    return out


def _fetch_huggingface_models(refresh: bool = False) -> list[dict]:
    if not refresh:
        cached = _load_discovery_cache("huggingface_inference")
        if cached is not None:
            return cached
    keys_for = grouped_keys().get("HF_TOKEN", [])
    if not keys_for:
        return []
    token = load_keys()[keys_for[0]]
    print(f"{C.D}discovering huggingface inference models…{C.R}", file=sys.stderr)
    try:
        req = urllib.request.Request(
            "https://router.huggingface.co/v1/models",
            headers={"Authorization": f"Bearer {token}"},
        )
        with urllib.request.urlopen(req, timeout=30) as r:
            data = json.loads(r.read())
    except Exception as e:
        err(f"huggingface discovery failed: {e}")
        return _load_discovery_cache("huggingface_inference", ignore_ttl=True) or []
    # HF gives every user $0.10/month free credits ($2/mo PRO) usable across
    # any routed model. So "free via HF" = any model with at least one live
    # provider; the user pays from credits at request time.
    out = []
    for m in data.get("data", []):
        mid = m.get("id")
        if not mid:
            continue
        providers = m.get("providers") or []
        live = [p for p in providers if p.get("status") == "live"]
        if not live:
            continue
        # Mark models that have at least one zero-priced provider so users can
        # filter to those if they want truly-free routes (no credit drain).
        has_free = any(
            _is_free_pricing({
                "prompt": (p.get("pricing") or {}).get("input"),
                "completion": (p.get("pricing") or {}).get("output"),
            })
            or p.get("provider") == "hf-inference"
            for p in live
        )
        out.append({
            "alias": f"hf/{mid}",
            "upstream": mid,
            "groups": _infer_hf_groups(mid, m.get("architecture") or {}, has_free),
        })
    _save_discovery_cache("huggingface_inference", out)
    return out


def _fetch_pollinations_models(refresh: bool = False) -> list[dict]:
    if not refresh:
        cached = _load_discovery_cache("pollinations")
        if cached is not None:
            return cached
    print(f"{C.D}discovering pollinations models…{C.R}", file=sys.stderr)
    try:
        with urllib.request.urlopen(
            "https://gen.pollinations.ai/v1/models", timeout=15
        ) as r:
            data = json.loads(r.read())
    except Exception as e:
        err(f"pollinations discovery failed: {e}")
        return _load_discovery_cache("pollinations", ignore_ttl=True) or []
    out = []
    for m in data.get("data", []):
        mid = m.get("id")
        endpoints = m.get("supported_endpoints") or []
        if not mid or "/v1/chat/completions" not in endpoints:
            continue
        out.append({
            "alias": f"poll/{mid}",
            "upstream": mid,
            "groups": _infer_pollinations_groups(m),
        })
    _save_discovery_cache("pollinations", out)
    return out


def _infer_pollinations_groups(m: dict) -> list[str]:
    out = ["pollinations", "free"]
    mid = (m.get("id") or "").lower()
    modalities = m.get("input_modalities") or []
    if "image" in modalities:
        out.append("vision")
    if m.get("reasoning"):
        out.append("reasoning")
    if any(t in mid for t in ("coder", "code-")):
        out.append("code")
    if any(t in mid for t in ("fast", "lite", "flash", "mini", "small")):
        out.append("fast")
    if any(t in mid for t in ("large", "pro", "ultra")):
        out.append("smart")
    return out


def _infer_hf_groups(mid: str, arch: dict | None = None, has_zero_priced: bool = False) -> list[str]:
    out = ["huggingface"]
    if has_zero_priced:
        out.append("free")
    name = mid.lower()
    modalities = (arch or {}).get("input_modalities") or []
    if "image" in modalities or any(t in name for t in ("vl", "vision", "vlm", "llava", "paligemma")):
        out.append("vision")
    if any(t in name for t in ("coder", "codellama", "code-", "codestral", "devstral")):
        out.append("code")
    if any(t in name for t in ("r1", "qwq", "thinking", "reasoning", "magistral", "o1-", "o3-")):
        out.append("reasoning")
    if "embed" in name:
        out.append("embed")
    return out

def _fetch_openrouter_free_models(refresh: bool = False) -> list[dict]:
    if not refresh:
        cached = _load_discovery_cache("openrouter_free")
        if cached is not None:
            return cached
    print(f"{C.D}discovering openrouter free models…{C.R}", file=sys.stderr)
    try:
        with urllib.request.urlopen(
            "https://openrouter.ai/api/v1/models", timeout=20
        ) as r:
            data = json.loads(r.read())
    except Exception as e:
        err(f"openrouter discovery failed: {e}")
        return _load_discovery_cache("openrouter_free", ignore_ttl=True) or []
    free: list[dict] = []
    for m in data.get("data", []):
        pricing = m.get("pricing") or {}
        if not _is_free_pricing(pricing):
            continue
        mid = m.get("id") or ""
        if not mid:
            continue
        cls = _classify_alias(mid)
        if cls == "drop":
            continue
        # OpenRouter exposes architecture.output_modalities. For chat models
        # require text output (drops image/video/audio gen). Embedding
        # models legitimately have output="embedding" so allow them through.
        arch = m.get("architecture") or {}
        out_modalities = arch.get("output_modalities")
        if cls == "chat" and isinstance(out_modalities, list) and out_modalities and "text" not in out_modalities:
            continue
        groups = _infer_or_groups(m)
        if cls == "embed" and "embed" not in groups:
            groups.append("embed")
        if cls == "rerank" and "rerank" not in groups:
            groups.append("rerank")
        free.append({
            "alias": mid,
            "upstream": mid,
            "groups": groups,
        })
    _save_discovery_cache("openrouter_free", free)
    return free

def _is_free_pricing(pricing: dict) -> bool:
    def zero(v) -> bool:
        try:
            return float(v) == 0.0
        except (TypeError, ValueError):
            return False
    return zero(pricing.get("prompt")) and zero(pricing.get("completion"))

def _infer_or_groups(m: dict) -> list[str]:
    out = ["free", "openrouter"]
    name = (m.get("id") or "").lower()
    arch = m.get("architecture") or {}
    modalities = arch.get("input_modalities") or []
    if "image" in modalities or "vision" in name or "-vl-" in name or "vl-" in name:
        out.append("vision")
    if any(t in name for t in ("coder", "-code-", "codestral", "devstral")):
        out.append("code")
    if any(t in name for t in (":r1", "/r1-", "o1-", "o3-", "thinking", "reasoning", "qwq", "magistral")):
        out.append("reasoning")
    if "embed" in name:
        out.append("embed")
    return out


# --- keystore -------------------------------------------------------------

_LINE = re.compile(r"^([A-Z][A-Z0-9_]*)=(.*)$")

def load_keys() -> dict[str, str]:
    if not KEYS_ENV.exists():
        return {}
    result: dict[str, str] = {}
    for raw in KEYS_ENV.read_text().splitlines():
        line = raw.strip()
        if not line or line.startswith("#"):
            continue
        m = _LINE.match(line)
        if m:
            result[m.group(1)] = m.group(2)
    return result

def save_keys(values: dict[str, str]) -> None:
    HOME.mkdir(parents=True, exist_ok=True)
    KEYS_ENV.write_text("".join(f"{k}={v}\n" for k, v in values.items()))
    KEYS_ENV.chmod(0o600)

def grouped_keys() -> dict[str, list[str]]:
    result: dict[str, list[str]] = {}
    for name in load_keys():
        base = re.sub(r"_\d+$", "", name)
        result.setdefault(base, []).append(name)
    return result

def add_key(key_env: str, value: str) -> str:
    values = load_keys()
    idx = 1
    while f"{key_env}_{idx}" in values:
        idx += 1
    name = f"{key_env}_{idx}"
    values[name] = value
    save_keys(values)
    return name

def remove_key(key_env: str, index: int | None = None) -> list[str]:
    values = load_keys()
    removed: list[str] = []
    if index is not None:
        name = f"{key_env}_{index}"
        if name in values:
            del values[name]
            removed.append(name)
    else:
        for name in list(values):
            if name == key_env or name.startswith(f"{key_env}_"):
                del values[name]
                removed.append(name)
    if removed:
        save_keys(values)
    return removed

def ensure_master_key() -> str:
    values = load_keys()
    if "LITELLM_MASTER_KEY" in values:
        return values["LITELLM_MASTER_KEY"]
    key = "sk-fi-" + secrets.token_urlsafe(32)
    values["LITELLM_MASTER_KEY"] = key
    save_keys(values)
    return key

def mask(value: str) -> str:
    return "•" * len(value) if len(value) <= 8 else f"{value[:4]}…{value[-4:]}"


# --- config generation ----------------------------------------------------

def _yaml_str(s: str) -> str:
    """Emit a string safe for our subset of YAML."""
    if any(c in s for c in ":#\n\"'") or s.strip() != s:
        return json.dumps(s)
    return s

def render_config(catalog: list[dict], grouped: dict[str, list[str]],
                  include_broken: bool = False) -> str:
    """Render LiteLLM config.yaml. Hand-written to avoid PyYAML.

    Each model_list entry is a concrete (alias, deployment) pair. We do NOT
    emit group names (fast/smart/etc.) as callable model_name entries —
    those caused opaque routing surprises. Group tags remain as filter
    metadata only; callers must name a specific alias.

    Aliases that have been probed and failed (per ~/.config/free-inference/
    .probe-cache.json) are automatically excluded — the router never picks
    them, clients never see them in /v1/models. Unprobed aliases pass
    through. Pass include_broken=True to emit everything (used by
    `./infer probe --include-broken` so it can retest previously-failed aliases).
    """
    lines = ["model_list:"]
    probe = load_probe_cache(ignore_ttl=True) or {}
    skipped_broken: list[str] = []

    for prov in catalog:
        key_vars = grouped.get(prov["key_env"], [])
        optional = prov.get("optional_key", False)
        if not key_vars and not optional:
            continue
        effective: list[str | None] = list(key_vars) if key_vars else [None]

        for model in prov.get("model", []):
            alias = model["alias"]
            # Skip aliases known-broken from probe. Unprobed → include.
            # include_broken=True bypasses the filter (probe retest mode).
            if not include_broken:
                pr = probe.get(alias)
                if pr is not None and not pr.get("ok"):
                    skipped_broken.append(alias)
                    continue
            for key_var in effective:
                lines.append(f"  - model_name: {_yaml_str(alias)}")
                lines.append("    litellm_params:")
                lines.append(f"      model: {_yaml_str(prov['litellm_prefix'] + '/' + model['upstream'])}")
                # LiteLLM's openai driver requires an api_key even for keyless
                # endpoints; pass a dummy when the provider is optional_key.
                if key_var:
                    lines.append(f"      api_key: os.environ/{key_var}")
                else:
                    lines.append(f"      api_key: unused")
                if prov.get("base_url"):
                    lines.append(f"      api_base: {_yaml_str(prov['base_url'])}")
                if model.get("rpm"):
                    lines.append(f"      rpm: {model['rpm']}")
                if model.get("tpm"):
                    lines.append(f"      tpm: {model['tpm']}")

    if skipped_broken:
        # Leave a breadcrumb in the generated file so users understand the
        # trim — purely informational since YAML comments are ignored.
        lines.insert(0, f"# Excluded {len(skipped_broken)} probe-failed aliases; run `./infer probe` to re-check.")

    lines += [
        "router_settings:",
        "  routing_strategy: usage-based-routing-v2",
        "  num_retries: 5",              # was 2 — cycle through more sibling deployments
        "  allowed_fails: 3",             # was 2 — tolerate a few failures before cooldown
        "  cooldown_time: 10",            # was 30 — recover faster
        "  retry_policy:",
        "    RateLimitErrorRetries: 3",
        "    TimeoutErrorRetries: 3",
        "    InternalServerErrorRetries: 3",
        "    BadRequestErrorRetries: 2",  # covers many provider 4xx incl 404 "not found for account"
        "    ContentPolicyViolationErrorRetries: 0",
        "    AuthenticationErrorRetries: 0",
        "general_settings:",
        "  master_key: os.environ/LITELLM_MASTER_KEY",
        "litellm_settings:",
        "  drop_params: true",
        "",
    ]
    return "\n".join(lines)

def write_config(include_broken: bool = False) -> list[dict]:
    ensure_master_key()
    catalog = load_catalog()
    grouped = grouped_keys()
    HOME.mkdir(parents=True, exist_ok=True)
    rendered = render_config(catalog, grouped, include_broken=include_broken)
    CONFIG_YAML.write_text(rendered)
    first = rendered.splitlines()[0] if rendered else ""
    if first.startswith("# Excluded "):
        print(f"{C.D}{first[2:]}{C.R}", file=sys.stderr)
    return [p for p in catalog if grouped.get(p["key_env"]) or p.get("optional_key")]


# --- docker compose -------------------------------------------------------

def compose(*args: str, capture: bool = False) -> subprocess.CompletedProcess:
    env = dict(os.environ)
    env["FI_HOME"] = str(HOME)
    return subprocess.run(
        ["docker", "compose", "-f", str(COMPOSE_FILE), *args],
        env=env,
        check=False,
        text=True,
        capture_output=capture,
    )


# --- health probes --------------------------------------------------------

def is_alive(timeout: float = 2.0) -> bool:
    try:
        with urllib.request.urlopen(f"{BASE_URL}/health/liveliness", timeout=timeout) as r:
            return r.status == 200
    except Exception:
        return False

def wait_alive(deadline: float = 60.0) -> bool:
    start = time.monotonic()
    while time.monotonic() - start < deadline:
        if is_alive():
            return True
        time.sleep(1)
    return False

def post(path: str, body: dict, headers: dict, timeout: float = 60.0) -> dict:
    req = urllib.request.Request(
        f"{BASE_URL}{path}",
        data=json.dumps(body).encode(),
        headers={"Content-Type": "application/json", **headers},
    )
    with urllib.request.urlopen(req, timeout=timeout) as r:
        return json.loads(r.read())


