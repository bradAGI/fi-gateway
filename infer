# --- global symlink (so `fi …` works from anywhere) -----------------------

def _install_target_dir(arg_dir: str | None) -> Path:
    if arg_dir:
        return Path(arg_dir).expanduser()
    return Path.home() / ".local" / "bin"

def _shell_rc() -> tuple[str, str]:
    """Return (rc-file-path, line-to-add) for the user's shell. Handles
    bash + zsh (Linux + macOS default) and fish."""
    shell = os.environ.get("SHELL", "")
    if "zsh" in shell:
        return "~/.zshrc", 'export PATH="$PATH:{}"'
    if "fish" in shell:
        return "~/.config/fish/config.fish", 'fish_add_path {}'
    return "~/.bashrc", 'export PATH="$PATH:{}"'

def cmd_install(args) -> int:
    target_dir = _install_target_dir(args.dir)
    target_dir.mkdir(parents=True, exist_ok=True)
    src = GATEWAY_DIR / "infer"
    name = args.name
    target = target_dir / name

    already = (target.is_symlink() and target.resolve() == src.resolve())
    if not already:
        if target.is_symlink() or target.exists():
            if not args.force:
                err(f"{target} already exists and isn't pointing at this fi — pass --force to overwrite")
                return 1
            target.unlink()
        target.symlink_to(src)
        ok(f"installed: {target} → {src}")
    else:
        ok(f"already installed: {target} → {src}")

    path_dirs = [Path(p).resolve() for p in os.environ.get("PATH", "").split(os.pathsep) if p]
    rc_file, fmt = _shell_rc()
    on_path = target_dir.resolve() in path_dirs
    shell = os.environ.get("SHELL", "")
    bash_or_zsh = "bash" in shell or "zsh" in shell
    name_collides = name == "fi" and bash_or_zsh

    if not on_path:
        out(f"{C.Y}NOTE: {target_dir} isn't on your $PATH.{C.R} Add this to {rc_file}:")
        out(f"  {fmt.format(target_dir)}")
    if name_collides:
        # `fi` is a reserved word in bash/zsh (closes if/then/fi blocks).
        # An alias works in interactive shells but breaks in scripts and
        # non-interactive subshells. The robust fix is renaming the symlink.
        out(f"{C.Y}NOTE: `fi` is a reserved word in bash/zsh — bare `fi` calls error.{C.R}")
        out(f"  Recommended: reinstall under a non-reserved name:")
        out(f"    ./infer install --name figw --force")
        out(f"  Or, for interactive shells only: add  alias fi='command fi'  to {rc_file}")
    if on_path and not name_collides:
        out(f"You can now run `{name}` from anywhere.")
    return 0

def cmd_uninstall(args) -> int:
    target_dir = _install_target_dir(args.dir)
    target = target_dir / args.name
    if target.is_symlink():
        target.unlink()
        ok(f"removed symlink: {target}")
        return 0
    if target.exists():
        err(f"{target} exists but isn't a symlink — leaving it alone")
        return 1
    out(f"nothing at {target}")
    return 0


def _fmt_age(ts: float) -> str:
    delta = max(0, int(time.time() - ts))
    if delta < 60: return f"{delta}s ago"
    if delta < 3600: return f"{delta // 60}m ago"
    if delta < 86400: return f"{delta // 3600}h {(delta % 3600) // 60}m ago"
    return f"{delta // 86400}d {(delta % 86400) // 3600}h ago"


def cmd_doctor(args) -> int:
    """One-shot health overview — proxy state, providers, keys, discovery,
    probe, drift, wired clients."""

    # --- gateway / proxy ----------------------------------------------------
    alive = is_alive()
    print(f"{C.B}GATEWAY{C.R}")
    print(f"  proxy: {C.G}up at {BASE_URL}{C.R}" if alive
          else f"  proxy: {C.RD}down{C.R} — run `./infer start`")
    master = load_keys().get("LITELLM_MASTER_KEY")
    if master:
        print(f"  master key: {mask(master)}")
    if CONFIG_YAML.exists():
        print(f"  config.yaml: regenerated {_fmt_age(CONFIG_YAML.stat().st_mtime)}")
    else:
        print(f"  config.yaml: {C.RD}missing{C.R}")

    # --- providers + keys ---------------------------------------------------
    catalog = load_catalog()
    grouped = grouped_keys()
    active = [p for p in catalog if grouped.get(p["key_env"]) or p.get("optional_key")]
    inactive = [p for p in catalog if p not in active]
    print(f"\n{C.B}PROVIDERS{C.R}  ({C.G}{len(active)} active{C.R}, {C.D}{len(inactive)} inactive{C.R})")
    if active:
        for p in active:
            keys = grouped.get(p["key_env"], [])
            label = f"{len(keys)} keys" if keys else f"{C.Y}keyless{C.R}"
            print(f"  {C.G}✓{C.R} {p['name']:<14} {label:<22} {len(p.get('model', []))} models")

    # --- discovery cache ----------------------------------------------------
    print(f"\n{C.B}DISCOVERY CACHE{C.R}")
    if DISCOVERY_CACHE.exists():
        try:
            disc = json.loads(DISCOVERY_CACHE.read_text())
        except Exception:
            disc = {}
        for kind, entry in disc.items():
            n = len(entry.get("models", []))
            age = _fmt_age(entry.get("t", 0))
            stale = (time.time() - entry.get("t", 0)) > DISCOVERY_TTL
            mark = f"{C.Y}STALE{C.R}" if stale else f"{C.G}fresh{C.R}"
            print(f"  {kind:<24} {n:>4} models · {age:<14} {mark}")
    else:
        print("  (no discovery cache yet — run `./infer sync`)")

    # --- probe cache --------------------------------------------------------
    print(f"\n{C.B}PROBE CACHE{C.R}")
    if PROBE_CACHE.exists():
        try:
            probe_data = json.loads(PROBE_CACHE.read_text())
        except Exception:
            probe_data = {}
        results = probe_data.get("results", {})
        ok_count = sum(1 for v in results.values() if v.get("ok"))
        fail_count = len(results) - ok_count
        age = _fmt_age(probe_data.get("t", 0))
        stale = (time.time() - probe_data.get("t", 0)) > PROBE_TTL
        mark = f"{C.Y}STALE{C.R}" if stale else f"{C.G}fresh{C.R}"
        print(f"  {C.G}{ok_count} working{C.R} · {C.RD}{fail_count} broken{C.R} · {len(results)} total · {age} · {mark}")
        # Drift: aliases in probe cache but no longer in catalog
        catalog_aliases = {m["alias"] for p in catalog for m in p.get("model", [])}
        ghosts = [a for a in results if a not in catalog_aliases]
        if ghosts:
            print(f"  {C.Y}drift: {len(ghosts)} probe entries no longer in catalog (run `./infer sync` to prune){C.R}")
    else:
        print("  (no probe cache yet — run `./infer probe`)")

    # --- exposed model count ------------------------------------------------
    if alive and master:
        try:
            req = urllib.request.Request(
                f"{BASE_URL}/v1/models",
                headers={"Authorization": f"Bearer {master}"},
            )
            with urllib.request.urlopen(req, timeout=5) as r:
                exposed = len(json.loads(r.read()).get("data", []))
            print(f"\n{C.B}EXPOSED{C.R}  {exposed} aliases callable via {BASE_URL}/v1/models")
        except Exception:
            pass

    # --- wired clients ------------------------------------------------------
    print(f"\n{C.B}WIRED CLIENTS{C.R}")
    targets = _wire_targets()
    for name, t in targets.items():
        installed = _tool_installed(t["binary"])
        if not installed:
            print(f"  {C.D}∅{C.R} {name:<10} (not installed)")
            continue
        cfg = _load_config(t["config"]) if t["config"].exists() else {}
        wired = t["check"](cfg)
        if wired:
            print(f"  {C.G}✓{C.R} {name:<10} wired → {t['config']}")
        else:
            print(f"  {C.D}·{C.R} {name:<10} installed but not wired ({C.B}./infer wire {name}{C.R})")

    return 0

