def cmd_sync(args) -> int:
    grouped = grouped_keys()
    catalog = load_catalog(refresh_discovery=True)
    any_dynamic = False
    for prov in catalog:
        if not prov.get("discovery"):
            continue
        any_dynamic = True
        has_key = bool(grouped.get(prov["key_env"]) or prov.get("optional_key"))
        if not has_key:
            print(f"{C.D}∅ {prov['name']}: skipped (no key — `./infer keys add {prov['name']} <key>`){C.R}")
            continue
        ok(f"{prov['name']}: {len(prov.get('model', []))} models cached")
    if not any_dynamic:
        out("No discoverable providers configured.")
    # Prune probe cache: drop entries for aliases no longer in the catalog.
    # Upstream catalogs churn (NVIDIA especially); stale probe entries cause
    # `./infer models --working` to list models the gateway can't actually route.
    all_aliases = {m["alias"] for p in catalog for m in p.get("model", [])}
    probe = load_probe_cache(ignore_ttl=True) or {}
    stale = [a for a in probe if a not in all_aliases]
    if stale:
        for a in stale:
            probe.pop(a, None)
        save_probe_cache(probe)
        out(f"{C.D}pruned {len(stale)} stale probe entries (no longer in catalog){C.R}")
    return 0

def _probe_one(master: str, alias: str, timeout: int = 20) -> tuple[str, dict]:
    """Fire one tiny chat.completions at the gateway for `alias`."""
    body = {
        "model": alias,
        "messages": [{"role": "user", "content": "hi"}],
        "max_tokens": 256,
    }
    req = urllib.request.Request(
        f"{BASE_URL}/v1/chat/completions",
        data=json.dumps(body).encode(),
        headers={"Authorization": f"Bearer {master}", "Content-Type": "application/json"},
    )
    start = time.monotonic()
    try:
        with urllib.request.urlopen(req, timeout=timeout) as r:
            data = json.loads(r.read())
        latency_ms = int((time.monotonic() - start) * 1000)
        msg = (data.get("choices") or [{}])[0].get("message") or {}
        has_content = bool(msg.get("content")) or bool(msg.get("reasoning_content"))
        usage = data.get("usage") or {}
        return alias, {
            "ok": has_content,
            "latency_ms": latency_ms,
            "completion_tokens": usage.get("completion_tokens", 0),
            "note": None if has_content else "empty response (may need higher max_tokens)",
        }
    except urllib.error.HTTPError as e:
        body_text = e.read().decode("utf-8", errors="replace")[:140]
        # Classify into common buckets so results are actionable
        if e.code == 429:
            note = f"429 rate-limited: {body_text[:80]}"
        elif e.code in (401, 403):
            note = f"{e.code} auth: {body_text[:80]}"
        elif e.code == 404:
            note = f"404 not found / unauthorized: {body_text[:80]}"
        elif 500 <= e.code < 600:
            note = f"{e.code} upstream error: {body_text[:60]}"
        else:
            note = f"{e.code}: {body_text[:80]}"
        return alias, {"ok": False, "code": e.code, "note": note}
    except Exception as e:
        return alias, {"ok": False, "note": f"{type(e).__name__}: {str(e)[:90]}"}


def _probe_one_embed(master: str, alias: str, timeout: int = 20) -> tuple[str, dict]:
    """Smoke-test an embedding alias via /v1/embeddings."""
    body = {"model": alias, "input": "test"}
    req = urllib.request.Request(
        f"{BASE_URL}/v1/embeddings",
        data=json.dumps(body).encode(),
        headers={"Authorization": f"Bearer {master}", "Content-Type": "application/json"},
    )
    start = time.monotonic()
    try:
        with urllib.request.urlopen(req, timeout=timeout) as r:
            data = json.loads(r.read())
        latency_ms = int((time.monotonic() - start) * 1000)
        records = data.get("data") or []
        vec = records[0].get("embedding") if records else None
        ok_flag = bool(vec) and isinstance(vec, list) and len(vec) > 0
        return alias, {
            "ok": ok_flag,
            "latency_ms": latency_ms,
            "endpoint": "embed",
            "dim": len(vec) if ok_flag else None,
            "note": None if ok_flag else "no embedding vector in response",
        }
    except urllib.error.HTTPError as e:
        body_text = e.read().decode("utf-8", errors="replace")[:140]
        if e.code == 429:
            note = f"429 rate-limited: {body_text[:80]}"
        elif e.code in (401, 403):
            note = f"{e.code} auth: {body_text[:80]}"
        elif e.code == 404:
            note = f"404 not found / unauthorized: {body_text[:80]}"
        else:
            note = f"{e.code}: {body_text[:80]}"
        return alias, {"ok": False, "code": e.code, "endpoint": "embed", "note": note}
    except Exception as e:
        return alias, {"ok": False, "endpoint": "embed", "note": f"{type(e).__name__}: {str(e)[:90]}"}


def cmd_probe(args) -> int:
    master = load_keys().get("LITELLM_MASTER_KEY")
    if not master:
        err("master key missing — run `./infer start` first")
        return 1
    if not is_alive():
        err("proxy is down — run `./infer start` first")
        return 1
    # --include-broken: regenerate config with probe-failed aliases re-added
    # and force-reload the container so we can actually test them. Without
    # this, previously-broken aliases 400 because they've been filtered out
    # of model_list by earlier renders.
    if args.include_broken:
        out(f"{C.D}re-rendering config with all aliases included (--include-broken)…{C.R}")
        write_config(include_broken=True)
        rc = compose("up", "-d", "--force-recreate", "litellm").returncode
        if rc != 0:
            err("failed to recreate container")
            return rc
        if not wait_alive():
            err("proxy did not come back up — check `./infer logs`")
            return 1
    catalog = load_catalog()
    grouped = grouped_keys()
    # (alias, kind) where kind ∈ {"chat","embed"}; rerank is skipped because
    # each provider's rerank API takes a different shape.
    targets: list[tuple[str, str]] = []
    seen: set[str] = set()
    for p in catalog:
        if not (grouped.get(p["key_env"]) or p.get("optional_key")):
            continue
        for m in p.get("model", []):
            if args.group and args.group not in m.get("groups", []):
                continue
            if args.provider and args.provider != p["name"]:
                continue
            alias = m["alias"]
            if alias in seen:
                continue
            mgroups = set(m.get("groups", []))
            if "rerank" in mgroups:
                continue  # no standard probe; users wire reranking explicitly
            kind = "embed" if "embed" in mgroups else "chat"
            seen.add(alias)
            targets.append((alias, kind))
    if args.limit:
        targets = targets[:args.limit]
    if not targets:
        err("no aliases to probe (try --group, --provider, or add keys)")
        return 1
    n_chat = sum(1 for _, k in targets if k == "chat")
    n_embed = sum(1 for _, k in targets if k == "embed")
    out(f"Probing {len(targets)} aliases at {BASE_URL} "
        f"({n_chat} chat, {n_embed} embed; concurrency={args.concurrency}, timeout={args.timeout}s)…")
    results: dict[str, dict] = {}
    # Preserve existing results for aliases we're not re-probing this run.
    existing = load_probe_cache(ignore_ttl=True) or {}
    results.update(existing)
    done = 0
    okc = failc = 0
    with ThreadPoolExecutor(max_workers=args.concurrency) as pool:
        futures = {}
        for alias, kind in targets:
            fn = _probe_one_embed if kind == "embed" else _probe_one
            futures[pool.submit(fn, master, alias, args.timeout)] = alias
        for fut in as_completed(futures):
            alias, result = fut.result()
            results[alias] = result
            done += 1
            if result.get("ok"):
                okc += 1
                mark = f"{C.G}✓{C.R}"
                detail = f"{result.get('latency_ms', '?')}ms"
            else:
                failc += 1
                mark = f"{C.RD}✗{C.R}"
                detail = result.get("note", "")
            print(f"  [{done:>3}/{len(targets)}] {mark} {alias:<48} {detail}", file=sys.stderr)
    save_probe_cache(results)
    out("")
    ok(f"{okc} working, {C.RD}{failc} broken{C.R} — results cached 24h at {PROBE_CACHE}")
    if args.include_broken:
        out(f"{C.Y}config currently includes all aliases — run `./infer reload` to re-apply the exclude-broken filter.{C.R}")
    out(f"Filter to working models: {C.B}./infer models --working{C.R}")
    return 0

def cmd_test_anthropic(args) -> int:
    master = load_keys().get("LITELLM_MASTER_KEY")
    if not master:
        err("master key missing — run `./infer start` first")
        return 1
    try:
        body = post(
            "/v1/messages",
            {
                "model": args.model,
                "max_tokens": 512,
                "messages": [{"role": "user", "content": args.prompt}],
            },
            {"x-api-key": master, "anthropic-version": "2023-06-01"},
        )
        text = "".join(b.get("text", "") for b in body.get("content", []) if b.get("type") == "text")
        print(text)
        return 0
    except urllib.error.HTTPError as e:
        err(f"{e.code} {e.reason}: {e.read().decode()}")
        return 1
    except Exception as e:
        err(f"failed: {e}")
        return 1


# --- wire: point client CLIs at the gateway -------------------------------
#
# Known wire targets. Each describes:
#   binary:  `which <name>` check
#   config:  JSON file we edit (resolved via Path.home() at call time)
#   check:   callable(config_json) -> bool, "already wired" detector
#   patch:   callable(config_json, master_key, gateway_url) -> new_json
#   unpatch: callable(config_json) -> new_json

FI_OPENAI_URL = f"{BASE_URL}/v1"
FI_ANTHROPIC_URL = BASE_URL
FI_PROVIDER_ID = "fi"
# Concrete aliases exposed to wired coding-agent CLIs. Deliberately a short,
# diverse list so their /model pickers aren't spammed; users can edit
# providers.toml or their client config to add more. Picked to cover a mix
# of providers (Gemini, NVIDIA, OpenRouter free, keyless LLM7).
FI_WIRE_MODELS = (
    "gemini-2.5-flash",
    "gemini-2.5-flash-lite",
    "meta/llama-3.3-70b-instruct",
    "deepseek-ai/deepseek-v3.2",
    "qwen/qwen3-coder-480b-a35b-instruct",
    "openrouter/free",
    "gpt-oss-llm7",
)


def _wire_pi_check(cfg: dict) -> bool:
    return FI_PROVIDER_ID in (cfg.get("providers") or {})

def _wire_pi_patch(cfg: dict, master: str) -> dict:
    providers = cfg.setdefault("providers", {})
    providers[FI_PROVIDER_ID] = {
        "baseUrl": FI_OPENAI_URL,
        "api": "openai-completions",
        "apiKey": master,
        "models": [
            {
                "id": mid,
                "name": f"fi/{mid}",
                # "vision" in alias is a good proxy; users can edit post-wire
                "reasoning": "r1" in mid or "reasoning" in mid,
                "input": ["text", "image"] if any(t in mid.lower() for t in ("gemini", "vision", "-vl-")) else ["text"],
                "contextWindow": 128000,
                "maxTokens": 4096,
                "cost": {"input": 0, "output": 0, "cacheRead": 0, "cacheWrite": 0},
            }
            for mid in FI_WIRE_MODELS
        ],
    }
    return cfg

def _wire_pi_unpatch(cfg: dict) -> dict:
    providers = cfg.get("providers") or {}
    providers.pop(FI_PROVIDER_ID, None)
    return cfg


def _wire_opencode_check(cfg: dict) -> bool:
    return FI_PROVIDER_ID in (cfg.get("provider") or {})

def _wire_opencode_patch(cfg: dict, master: str) -> dict:
    cfg.setdefault("$schema", "https://opencode.ai/config.json")
    providers = cfg.setdefault("provider", {})
    providers[FI_PROVIDER_ID] = {
        "npm": "@ai-sdk/openai-compatible",
        "name": "fi gateway",
        "options": {"baseURL": FI_OPENAI_URL, "apiKey": master},
        "models": {mid: {"name": f"fi/{mid}"} for mid in FI_WIRE_MODELS},
    }
    return cfg

def _wire_opencode_unpatch(cfg: dict) -> dict:
    providers = cfg.get("provider") or {}
    providers.pop(FI_PROVIDER_ID, None)
    return cfg


def _wire_cc_check(cfg: dict) -> bool:
    env = cfg.get("env") or {}
    return env.get("ANTHROPIC_BASE_URL") == FI_ANTHROPIC_URL

def _wire_cc_patch(cfg: dict, master: str) -> dict:
    env = cfg.setdefault("env", {})
    env["ANTHROPIC_BASE_URL"] = FI_ANTHROPIC_URL
    env["ANTHROPIC_API_KEY"] = master
    return cfg

def _wire_cc_unpatch(cfg: dict) -> dict:
    env = cfg.get("env") or {}
    if env.get("ANTHROPIC_BASE_URL") == FI_ANTHROPIC_URL:
        env.pop("ANTHROPIC_BASE_URL", None)
        env.pop("ANTHROPIC_API_KEY", None)
    return cfg


def _wire_openclaw_check_text(cfg_text: str) -> bool:
    return BASE_URL in cfg_text and FI_PROVIDER_ID in cfg_text

def _wire_openclaw_run(master: str) -> int:
    """Shell out to openclaw's onboarding CLI to register fi as a custom
    OpenAI-compatible provider. openclaw owns the YAML format."""
    return subprocess.run([
        "openclaw", "onboard",
        "--auth-choice", "custom-api-key",
        "--custom-provider-id", FI_PROVIDER_ID,
        "--custom-base-url", FI_OPENAI_URL,
        "--custom-api-key", master,
        "--custom-model-id", FI_WIRE_MODELS[0],
        "--custom-compatibility", "openai",
    ]).returncode


def _wire_hermes_check_text(cfg_text: str) -> bool:
    return BASE_URL in cfg_text and "provider: custom" in cfg_text

def _wire_hermes_run(master: str) -> int:
    """Use hermes config set commands — hermes owns the YAML format."""
    pairs = [
        ("model.provider", "custom"),
        ("model.base_url", FI_OPENAI_URL),
        ("model.api_key", master),
        ("model.default", FI_WIRE_MODELS[0]),
    ]
    for key, val in pairs:
        rc = subprocess.run(["hermes", "config", "set", key, val]).returncode
        if rc != 0:
            return rc
    return 0


def _wire_targets() -> dict:
    return {
        "pi": {
            "binary": "pi",
            "config": Path.home() / ".pi" / "agent" / "models.json",
            "kind": "json",
            "check": _wire_pi_check,
            "patch": _wire_pi_patch,
            "unpatch": _wire_pi_unpatch,
        },
        "opencode": {
            "binary": "opencode",
            "config": Path.home() / ".config" / "opencode" / "opencode.json",
            "kind": "json",
            "check": _wire_opencode_check,
            "patch": _wire_opencode_patch,
            "unpatch": _wire_opencode_unpatch,
        },
        "cc": {
            "binary": "claude",
            "config": Path.home() / ".claude" / "settings.json",
            "kind": "json",
            "check": _wire_cc_check,
            "patch": _wire_cc_patch,
            "unpatch": _wire_cc_unpatch,
        },
        "openclaw": {
            "binary": "openclaw",
            "config": Path.home() / ".openclaw" / "config.yaml",
            "kind": "cli",
            "check_text": _wire_openclaw_check_text,
            "wire_run": _wire_openclaw_run,
        },
        "hermes": {
            "binary": "hermes",
            "config": Path.home() / ".hermes" / "config.yaml",
            "kind": "cli",
            "check_text": _wire_hermes_check_text,
            "wire_run": _wire_hermes_run,
        },
    }


def _is_wired(t: dict) -> bool:
    """Generic wiring check across json + cli kinds."""
    cfg_path = t["config"]
    if t.get("kind") == "cli":
        text = cfg_path.read_text() if cfg_path.exists() else ""
        return t["check_text"](text)
    cfg = _load_config(cfg_path) if cfg_path.exists() else {}
    return t["check"](cfg)


def _tool_installed(binary: str) -> bool:
    rc = subprocess.run(["bash", "-lc", f"command -v {binary}"],
                        capture_output=True, text=True).returncode
    return rc == 0


def _load_config(path: Path) -> dict:
    if not path.exists() or path.stat().st_size == 0:
        return {}
    try:
        return json.loads(path.read_text())
    except json.JSONDecodeError:
        err(f"config at {path} is not valid JSON")
        raise


def _save_config(path: Path, data: dict, mode: int | None = None) -> None:
    path.parent.mkdir(parents=True, exist_ok=True)
    text = json.dumps(data, indent=2) + "\n"
    path.write_text(text)
    if mode is not None:
        # Existing-file O_CREAT won't reset perms; chmod explicitly.
        path.chmod(mode)


def _backup_path(path: Path) -> Path:
    return path.with_suffix(path.suffix + ".fi-backup")


def cmd_detect(args) -> int:
    targets = _wire_targets()
    print(f"{'Tool':<10} {'Installed':<11} {'Config':<50} Status")
    print("-" * 90)
    for name, t in targets.items():
        installed = _tool_installed(t["binary"])
        if not installed:
            print(f"{name:<10} {C.D}no{C.R:<19} {'—':<50} {C.D}(not installed){C.R}")
            continue
        wired = _is_wired(t)
        status = f"{C.G}wired to fi{C.R}" if wired else f"{C.Y}not wired{C.R}"
        cfg_display = str(t["config"])
        if len(cfg_display) > 49:
            cfg_display = "…" + cfg_display[-48:]
        print(f"{name:<10} {C.G}yes{C.R:<19} {cfg_display:<50} {status}")
    return 0


def cmd_wire(args) -> int:
    targets = _wire_targets()
    t = targets.get(args.tool)
    if not t:
        err(f"unknown tool: {args.tool} (expected one of: {', '.join(targets)})")
        return 1
    if not _tool_installed(t["binary"]):
        err(f"{args.tool} is not installed — skipping")
        return 1
    master = load_keys().get("LITELLM_MASTER_KEY")
    if not master:
        master = ensure_master_key()
        out(f"{C.D}generated master key (will be used by {args.tool}){C.R}")
    cfg_path = t["config"]
    if _is_wired(t):
        out(f"{args.tool} is already wired to fi. Run `./infer unwire {args.tool}` to undo.")
        return 0
    if cfg_path.exists():
        backup = _backup_path(cfg_path)
        backup.write_text(cfg_path.read_text())
        ok(f"backed up {cfg_path} → {backup}")
    if t.get("kind") == "cli":
        # The tool owns its config format — shell out to its CLI.
        rc = t["wire_run"](master)
        if rc != 0:
            err(f"{args.tool} CLI returned exit {rc}; check the output above.")
            return rc
    else:
        cfg = _load_config(cfg_path) if cfg_path.exists() else {}
        new_cfg = t["patch"](cfg, master)
        mode = 0o600 if args.tool == "cc" else None
        _save_config(cfg_path, new_cfg, mode=mode)
    ok(f"wired {args.tool} — config at {cfg_path}")
    out(f"  - base URL: {FI_OPENAI_URL if args.tool != 'cc' else FI_ANTHROPIC_URL}")
    out(f"  - master key: {mask(master)}")
    out(f"Start the gateway with `./infer start` (if not already running).")
    return 0


def cmd_unwire(args) -> int:
    targets = _wire_targets()
    t = targets.get(args.tool)
    if not t:
        err(f"unknown tool: {args.tool} (expected one of: {', '.join(targets)})")
        return 1
    cfg_path = t["config"]
    backup = _backup_path(cfg_path)
    if backup.exists():
        cfg_path.write_text(backup.read_text())
        backup.unlink()
        ok(f"restored {cfg_path} from backup, removed {backup}")
        return 0
    if not cfg_path.exists():
        out(f"no config at {cfg_path} — nothing to unwire")
        return 0
    if t.get("kind") == "cli":
        # CLI-managed configs don't have a clean structured undo without
        # a backup. The wire flow always writes one before calling the
        # tool's CLI, so this branch only fires if the user deleted the
        # backup or wired manually.
        out(f"no backup found at {backup}; manually edit {cfg_path} to remove the fi block")
        return 0
    cfg = _load_config(cfg_path)
    if not t["check"](cfg):
        out(f"{args.tool} is not wired to fi — nothing to do")
        return 0
    new_cfg = t["unpatch"](cfg)
    _save_config(cfg_path, new_cfg)
    ok(f"removed fi provider from {cfg_path}")
    return 0


# --- argparse wiring ------------------------------------------------------

def build_parser() -> argparse.ArgumentParser:
    p = argparse.ArgumentParser(prog="infer", description="Free-inference gateway CLI")
    sub = p.add_subparsers(dest="cmd", required=True)

    sub.add_parser("start", help="Generate config and start the proxy").set_defaults(fn=cmd_start)
    sub.add_parser("stop", help="Stop the proxy").set_defaults(fn=cmd_stop)
    sub.add_parser("restart", help="Restart without regenerating config").set_defaults(fn=cmd_restart)
    sub.add_parser("reload", help="Regenerate config and bounce proxy").set_defaults(fn=cmd_reload)
    sub.add_parser("status", help="Show proxy + provider status").set_defaults(fn=cmd_status)
    sub.add_parser("doctor", help="One-shot health overview: gateway, providers, keys, discovery + probe age, drift, wired clients").set_defaults(fn=cmd_doctor)

    pi_install = sub.add_parser("install", help="Symlink fi into a directory on $PATH so the command works from anywhere")
    pi_install.add_argument("--dir", default=None, help="Target dir (default: ~/.local/bin)")
    pi_install.add_argument("--name", default="infer", help="Symlink name (default: infer)")
    pi_install.add_argument("--force", action="store_true", help="Overwrite an existing entry")
    pi_install.set_defaults(fn=cmd_install)
    pu_install = sub.add_parser("uninstall", help="Remove the symlink created by `./infer install`")
    pu_install.add_argument("--dir", default=None, help="Target dir (default: ~/.local/bin)")
    pu_install.add_argument("--name", default="infer", help="Symlink name to remove (default: infer)")
    pu_install.set_defaults(fn=cmd_uninstall)

    pl = sub.add_parser("logs", help="Tail litellm logs")
    pl.add_argument("--follow", "-f", action="store_true")
    pl.set_defaults(fn=cmd_logs)

    pk = sub.add_parser("keys", help="Manage API keys")
    ks = pk.add_subparsers(dest="keys_cmd", required=True)
    pa = ks.add_parser("add", help="Add a key for a provider")
    pa.add_argument("provider"); pa.add_argument("key")
    pa.set_defaults(fn=cmd_keys_add)
    ks.add_parser("list", help="List configured keys (masked)").set_defaults(fn=cmd_keys_list)
    pr = ks.add_parser("remove", help="Remove a key")
    pr.add_argument("provider"); pr.add_argument("--index", type=int, default=None)
    pr.set_defaults(fn=cmd_keys_remove)

    sub.add_parser("providers", help="Show enabled vs available providers").set_defaults(fn=cmd_providers)
    sub.add_parser("sync", help="Refresh dynamically-discovered model lists (e.g. OpenRouter)").set_defaults(fn=cmd_sync)
    pm = sub.add_parser("models", help="List model aliases")
    pm.add_argument("--group", "-g", default=None)
    pm.add_argument("--working", "-w", action="store_true", help="Only show models that passed `./infer probe`")
    pm.add_argument("--broken", action="store_true", help="Only show models that failed `./infer probe` (or were never probed)")
    pm.set_defaults(fn=cmd_models)

    pp = sub.add_parser("probe", help="Smoke-test every alias against the proxy; cache which models work (24h)")
    pp.add_argument("--group", "-g", default=None, help="Only probe models in this group")
    pp.add_argument("--provider", "-p", default=None, help="Only probe models from this provider")
    pp.add_argument("--limit", "-n", type=int, default=None, help="Probe at most N aliases")
    pp.add_argument("--concurrency", "-c", type=int, default=8, help="Parallel probes (default 8)")
    pp.add_argument("--timeout", "-t", type=int, default=20, help="Per-probe timeout seconds (default 20)")
    pp.add_argument("--include-broken", action="store_true",
                    help="Temporarily re-render config without the exclude-broken filter so previously-failed aliases can be retested. Run `./infer reload` after to re-apply the filter.")
    pp.set_defaults(fn=cmd_probe)

    pc = sub.add_parser("config", help="Inspect generated config")
    cs = pc.add_subparsers(dest="config_cmd", required=True)
    cs.add_parser("show").set_defaults(fn=cmd_config_show)
    cs.add_parser("path").set_defaults(fn=cmd_config_path)

    pt = sub.add_parser("test", help="OpenAI-shape smoke test")
    pt.add_argument("model"); pt.add_argument("--prompt", default="Reply with the word READY.")
    pt.set_defaults(fn=cmd_test)

    sub.add_parser("detect", help="Scan for installed client CLIs (pi, opencode, cc) and show wiring status").set_defaults(fn=cmd_detect)
    pw = sub.add_parser("wire", help="Wire a client CLI to the fi gateway (edits its config, saves .fi-backup)")
    pw.add_argument("tool", choices=["pi", "opencode", "cc", "openclaw", "hermes"])
    pw.set_defaults(fn=cmd_wire)
    pu = sub.add_parser("unwire", help="Remove fi from a client CLI's config (restores from .fi-backup if present)")
    pu.add_argument("tool", choices=["pi", "opencode", "cc", "openclaw", "hermes"])
    pu.set_defaults(fn=cmd_unwire)

    pan = sub.add_parser("test-anthropic", help="Anthropic-shape /v1/messages smoke test")
    pan.add_argument("model"); pan.add_argument("--prompt", default="Reply with the word READY.")
    pan.set_defaults(fn=cmd_test_anthropic)

    return p


if __name__ == "__main__":
    args = build_parser().parse_args()
    sys.exit(args.fn(args))
