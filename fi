def cmd_models(args) -> int:
    catalog = load_catalog()
    grouped = grouped_keys()
    probe = load_probe_cache() if (args.working or args.broken) else None
    if (args.working or args.broken) and probe is None:
        err("no probe cache (or stale) — run `./fi probe` first")
        return 1
    rows = []
    for p in catalog:
        if not (grouped.get(p["key_env"]) or p.get("optional_key")):
            continue
        for m in p.get("model", []):
            if args.group and args.group not in m.get("groups", []):
                continue
            if probe is not None:
                result = probe.get(m["alias"])
                if args.working and not (result and result.get("ok")):
                    continue
                if args.broken and (result is None or result.get("ok")):
                    continue
            rows.append((m["alias"], p["name"], ",".join(m.get("groups", []))))
    width = max((len(a) for a, _, _ in rows), default=35)
    print(f"{'Alias':<{width}}  {'Provider':<14} Groups")
    print("-" * (width + 30))
    for alias, prov, groups in rows:
        print(f"{alias:<{width}}  {prov:<14} {groups}")
    print(f"\n{len(rows)} models")
    return 0

